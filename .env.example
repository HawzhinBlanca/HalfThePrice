# Database
DATABASE_URL="postgresql://htp:htp_dev_password@localhost:5433/half_the_price?schema=public"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# Cron (stale listing processor)
CRON_SECRET="change-me-for-stale-listing-cron"

# KYC storage (local fallback when MinIO unavailable)
KYC_UPLOAD_DIR="./uploads/kyc"

# MinIO / S3-compatible KYC storage
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="htp_minio"
MINIO_SECRET_KEY="htp_minio_dev_password"
MINIO_BUCKET="htp-kyc"
MINIO_REGION="us-east-1"

# Meilisearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="htp_meili_dev_key"

# Centrifugo realtime chat
CENTRIFUGO_API_URL="http://localhost:8000"
CENTRIFUGO_TOKEN_SECRET="htp_centrifugo_dev_secret"
CENTRIFUGO_API_KEY="htp_centrifugo_api_key"
NEXT_PUBLIC_CENTRIFUGO_WS_URL="ws://localhost:8000/connection/websocket"

# Payments (sandbox webhooks)
PAYMENT_WEBHOOK_SECRET="change-me-for-payment-webhooks"

# Sentry (optional — works without DSN in dev)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# CSRF (set true only for local e2e/tests)
CSRF_DISABLED="false"

# Mobile app
EXPO_PUBLIC_API_URL="http://localhost:3000"
