generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SellerKycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KycDocumentType {
  TRADE_LICENSE
  NATIONAL_ID
  OTHER
}

enum CategoryWhitelistStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum ListingStatus {
  DRAFT
  PENDING_VERIFICATION
  MANUAL_REVIEW
  LIVE
  REJECTED
  STALE
  HIDDEN
}

enum ListingCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

enum VerificationResult {
  PASS
  FAIL
  MANUAL_REVIEW
  PENDING
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_PROCESSING
  CONFIRMED
  CANCELLED
  FAILED
  COD_PENDING
}

enum PaymentMethod {
  COD
  ZAINCASH
  QICARD
  FASTPAY
}

enum PaymentIntentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  phone        String?
  role         UserRole   @default(BUYER)
  status       UserStatus @default(ACTIVE)
  locale       String     @default("en")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sellerProfile       SellerProfile?
  listings            Listing[]            @relation("SellerListings")
  offers              Offer[]              @relation("BuyerOffers")
  auditEvents         AuditEvent[]
  buyerOrders         Order[]              @relation("BuyerOrders")
  sellerOrders        Order[]              @relation("SellerOrders")
  buyerConversations  Conversation[]       @relation("BuyerConversations")
  sellerConversations Conversation[]       @relation("SellerConversations")
  sentMessages        Message[]

  @@map("users")
}

model SellerProfile {
  id               String          @id @default(cuid())
  userId           String          @unique
  legalName        String
  displayName      String
  governorate      String
  kycStatus        SellerKycStatus @default(PENDING)
  payoutPreference String?
  licenseNumber    String?
  contactPhone     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kycDocuments KycDocument[]

  @@map("seller_profiles")
}

model KycDocument {
  id              String          @id @default(cuid())
  sellerProfileId String
  documentType    KycDocumentType
  fileName        String
  filePath        String
  mimeType        String
  fileSizeBytes   Int
  uploadedAt      DateTime        @default(now())

  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@index([sellerProfileId])
  @@map("kyc_documents")
}

model Category {
  id                   String                  @id @default(cuid())
  slug                 String                  @unique
  nameEn               String
  nameAr               String?
  nameKu               String?
  whitelistStatus      CategoryWhitelistStatus @default(ACTIVE)
  retailTtlDays        Int                     @default(30)
  verificationPolicy   String                  @default("STANDARD")
  matchConfidenceThreshold Float               @default(0.85)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  canonicalProducts CanonicalProduct[]
  listings          Listing[]

  @@map("categories")
}

model CanonicalProduct {
  id               String   @id @default(cuid())
  categoryId       String
  brand            String
  model            String
  gtin             String?
  mpn              String?
  normalizedSpecs  Json?
  fingerprintHash  String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category         Category          @relation(fields: [categoryId], references: [id])
  listings         Listing[]
  retailReferences RetailReference[]

  @@index([brand, model])
  @@map("canonical_products")
}

model RetailReference {
  id                 String   @id @default(cuid())
  canonicalProductId String
  sourceName         String
  sourceUrl          String
  observedPriceIqd   Int
  stockState         String   @default("IN_STOCK")
  observedAt         DateTime @default(now())
  parserVersion      String   @default("1.0.0")
  evidenceHash       String
  createdAt          DateTime @default(now())

  canonicalProduct CanonicalProduct @relation(fields: [canonicalProductId], references: [id], onDelete: Cascade)

  verificationRuns PriceVerificationRun[]

  @@index([canonicalProductId, observedAt])
  @@map("retail_references")
}

model Listing {
  id                 String           @id @default(cuid())
  sellerId           String
  canonicalProductId String?
  categoryId         String
  title              String
  description        String?
  condition          ListingCondition @default(GOOD)
  accessories        String?
  sellerPriceIqd     Int
  status             ListingStatus    @default(DRAFT)
  governorate        String
  imageUrl           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  publishedAt        DateTime?

  seller           User                   @relation("SellerListings", fields: [sellerId], references: [id])
  category         Category               @relation(fields: [categoryId], references: [id])
  canonicalProduct CanonicalProduct?      @relation(fields: [canonicalProductId], references: [id])
  verificationRuns PriceVerificationRun[]
  offers           Offer[]
  conversations    Conversation[]

  @@index([status, governorate])
  @@index([sellerId])
  @@map("listings")
}

model PriceVerificationRun {
  id                   String             @id @default(cuid())
  listingId            String
  matchConfidence      Float
  selectedReferenceId  String?
  verifiedRetailIqd    Int?
  computedCapIqd       Int?
  result               VerificationResult @default(PENDING)
  reviewerId           String?
  message              String?
  createdAt            DateTime           @default(now())

  listing             Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  selectedReference   RetailReference? @relation(fields: [selectedReferenceId], references: [id])

  @@index([listingId, createdAt])
  @@map("price_verification_runs")
}

model Offer {
  id              String      @id @default(cuid())
  listingId       String
  buyerId         String
  amountIqd       Int
  capSnapshotIqd  Int
  status          OfferStatus @default(PENDING)
  message         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User    @relation("BuyerOffers", fields: [buyerId], references: [id])
  order   Order?

  @@index([listingId])
  @@map("offers")
}

model Order {
  id            String        @id @default(cuid())
  offerId       String        @unique
  listingId     String
  buyerId       String
  sellerId      String
  amountIqd     Int
  status        OrderStatus   @default(PENDING_PAYMENT)
  paymentMethod PaymentMethod @default(COD)
  codEnabled    Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  confirmedAt   DateTime?

  offer         Offer          @relation(fields: [offerId], references: [id], onDelete: Cascade)
  buyer         User           @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller        User           @relation("SellerOrders", fields: [sellerId], references: [id])
  paymentIntent PaymentIntent?

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("orders")
}

model PaymentIntent {
  id          String              @id @default(cuid())
  orderId     String              @unique
  provider    PaymentMethod
  status      PaymentIntentStatus @default(PENDING)
  providerRef String?
  sandbox     Boolean             @default(true)
  metadata    Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payment_intents")
}

model Conversation {
  id        String   @id @default(cuid())
  listingId String
  buyerId   String
  sellerId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    User      @relation("BuyerConversations", fields: [buyerId], references: [id])
  seller   User      @relation("SellerConversations", fields: [sellerId], references: [id])
  messages Message[]

  @@unique([listingId, buyerId, sellerId])
  @@index([listingId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

model AuditEvent {
  id            String   @id @default(cuid())
  actorId       String?
  objectType    String
  objectId      String
  action        String
  before        Json?
  after         Json?
  correlationId String?
  createdAt     DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([objectType, objectId])
  @@map("audit_events")
}
