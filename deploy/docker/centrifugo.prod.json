{
  "token_hmac_secret_key": "${CENTRIFUGO_TOKEN_SECRET}",
  "api_key": "${CENTRIFUGO_API_KEY}",
  "allowed_origins": ["*"],
  "namespaces": [
    {
      "name": "chat",
      "presence": true,
      "history_size": 200,
      "history_ttl": "600s",
      "allow_subscribe_for_client": true,
      "allow_publish_for_client": true
    }
  ]
}
